<div class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="relative isolate overflow-hidden bg-gray-900 px-6 py-24 shadow-2xl sm:rounded-3xl sm:px-24 xl:py-32">
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-brand_yellow italic">Ready to elevate your online business?</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl pb-4">Contact RPTRAINOR today for<br/>your free consultation</h2>
