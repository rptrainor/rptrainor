---
export const prerender = true;
---
<!-- Cal inline embed code begins -->
<div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline"></div>
<script type="text/javascript">
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {}; cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, "https://app.cal.com/embed/embed.js", "init");

  Cal("init",  {origin:"https://cal.com"});

  Cal("inline", {
    elementOrSelector: "#my-cal-inline",
    calLink: "rptrainor/boost-your-page-conversions-free-strategy-session",
    layout: "column_view"
  });

  Cal("ui", {"theme":"dark","styles":{"branding":{"brandColor":"#181E23"}},"hideEventTypeDetails":false,"layout":"column_view"});

  // Set title for the iframe
  const setTitleForIframe = () => {
    const iframes = document.querySelectorAll('#my-cal-inline iframe');
    if (iframes.length > 0) {
      iframes.forEach(iframe => {
        iframe.title = "Calendar to book your free strategy session";
      });
    }
  };

  // Use MutationObserver to detect when the iframe is added to the DOM
  const observer = new MutationObserver((mutationsList, observer) => {
    for (let mutation of mutationsList) {
      if (mutation.type === 'childList') {
        setTitleForIframe();
      }
    }
  });

  // Start observing the target node for configured mutations
  observer.observe(document.getElementById('my-cal-inline'), { attributes: true, childList: true, subtree: true });
</script>
<!-- Cal inline embed code ends -->
