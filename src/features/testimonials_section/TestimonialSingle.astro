---
export const prerender = true
import crossWhite50 from '~/features/testimonials_section/cross_white_50.webp'
// import chinChinChino_white_154x48 from '~/features/testimonials_section/chinChinChino_white_154x48.webp'
// import ava_avatar_100x100 from '~/features/testimonials_section/ava_avatar_100x100.webp'
import wenchi_avatar_100x100 from '~/features/testimonials_section/wenchi_avatar_100x100.webp'
import AstroImage from '~/layouts/AstroImage.astro'
---

<div>
	<div class="mx-auto max-w-2xl text-center">
		<p
			style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
			class="mx-auto mb-4 mt-6 max-w-md text-pretty text-xl font-bold italic leading-snug text-brand_yellow sm:text-2xl"
		>
			Transforming Lost Opportunities into Real Growth and Profit
		</p>
		<h2
			style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
			class="text-pretty text-2xl font-black leading-snug text-white sm:text-4xl sm:leading-tight"
		>
			Where 'No Code' Falls Short, RPTrainor Excels
		</h2>
		<p
			style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
			class="mx-auto mb-4 mt-6 max-w-md text-pretty text-xl font-bold italic leading-snug text-brand_yellow sm:text-2xl"
		>
			See For Yourself&#8230;
		</p>
	</div>
	<section class="py-4 sm:py-12">
		<div class="">
			<div class="mx-auto grid max-w-none grid-cols-1">
				<div class="flex flex-col pb-10">
					<div class="flex w-fit flex-nowrap items-center gap-0">
						<AstroImage
							class="h-12 w-12"
							src={crossWhite50}
							alt="Cornerstone Integrative Psychiatry"
						/>
						<div class="flex h-full flex-col items-stretch rounded px-1 transition-colors">
							<h1
								style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
								class="m-0 grow p-0 text-left text-2xl font-bold leading-none text-white sm:text-3xl"
							>
								Cornerstone
							</h1>
							<p
								style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
								class="m-0 p-0 text-sm leading-none text-white/60"
							>
								Integrative Psychiatric
							</p>
						</div>
					</div>
					<figure class="mt-10 flex flex-auto flex-col justify-between">
						<blockquote class="grow text-lg leading-8 text-white">
							<p style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;">
								“Ryan is very attentive and detailed oriented! As a new business owner, I have had a lot of questions and concepts in my mind about a website and he has been very patient to answer everyone of them and giving some recommendations.
								Ryan is also very responsive and easy to communicate with. Most importantly, he is a professional in what he does and provided many options instead of just going through a template! I highly recommend their service!”
							</p>
						</blockquote>
						<figcaption class="mt-10 flex h-20 items-center gap-x-6">
							<AstroImage
								class="h-14 w-14 rounded-full bg-gray-50"
								src={wenchi_avatar_100x100}
								alt="Wenchi Fan"
								height={56}
								width={56}
							/>
							<div class="text-base">
								<p
									style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
									class="font-semibold text-white"
								>
									CEO of ChinChinChino
								</p>
								<p
									style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
									class="mt-1 text-white/60"
								>
									CEO of Cornerstone Integrative Psychiatry
								</p>
							</div>
						</figcaption>
					</figure>
				</div>
				<!-- <div
					class="flex flex-col border-t border-gray-900/10 pt-10 sm:pt-16 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0 xl:pl-20"
				>
					<AstroImage
						class="h-12"
						src={chinChinChino_white_154x48}
						alt="ChinChinChino"
						height={48}
						width={154}
					/>
