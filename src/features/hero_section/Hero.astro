---
import ScreenShot from '../../features/hero_section/ScreenShot.astro'
export const prerender = true
---

<div class="mx-auto flex flex-col items-center">
	<p
		style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
		class="mx-auto text-pretty text-center text-4xl italic text-brand_yellow"
	>
		Struggling To Get More Customers<br />with your "No Code" tools?
	</p>
	<h1
		style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
		class="text-center text-4xl font-black leading-tight text-white sm:text-8xl"
	>
		Increase Conversions
	</h1>
	<ScreenShot />
	<p
		style="font-family: 'Montserrat', 'Montserrat Variable', sans-serif;"
		class="text-pretty py-4 text-center text-lg font-bold leading-snug text-white sm:text-4xl"
	>
		Transform Your "No Code" Pages with Perfect 100 Google Lighthouse Scores<br />or Your Money Back
	</p>
</div>
