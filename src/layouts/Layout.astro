---
// * src/layouts/Layout.astro
export const prerender = true
import '@fontsource-variable/montserrat'
import '@fontsource/delicious-handrawn'
import { ViewTransitions } from 'astro:transitions'

import Header from '~/features/header_section/HeaderSection.astro'
// import Posthog from '~/analytics/Posthog.astro'
interface Props {
	title: string
	description: string
}

const { title, description } = Astro.props
---

<!doctype html>
<html lang="en-US">
	<head>
		<link
			rel="preload"
			href="/fonts/delicious-handrawn-latin-400-normal.woff"
			as="font"
			type="font/woff"
			crossorigin
		/>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={Astro.url} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#181e23" />
		<meta name="msapplication-TileColor" content="#181e23" />
		<meta name="theme-color" content="#181e23" />
		{/* SEO Meta Tags */}
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="Ryan P Trainor Newsletter, Web Performance Tips, App Optimization Strategies, Sales Funnel Best Practices, Landing Page Design Insights, Tech Innovations by Ryan P Trainor, Software Development Techniques, Business Growth Hacks, Digital Marketing Trends, High-Performance Computing, Entrepreneurial Insights, User Experience Best Practices, Technology Leadership, Efficient Coding Practices, Ryan P Trainor Tech Insights"
		/>

		<link rel="manifest" href="/site.webmanifest" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		{/* Open Graph Meta Tags */}
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />

		{/* Theme Color for Mobile Browsers */}
		<meta name="theme-color" content="#181E23" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />
	</head>
	<body class="mx-auto max-w-7xl bg-brand_black p-4">
		<Header />
		<slot />
		<style is:global>
			@tailwind base;
			@tailwind utilities;

			@font-face {
				font-family: 'Delicious Handrawn';
				src: url('/fonts/delicious-handrawn-latin-400-normal.woff') format('woff');
				font-weight: normal;
				font-style: normal;
				font-display: swap;
			}

			body,
			html {
				margin: 0;
				padding: 0;
				width: 100%;
				min-width: 0;
				font-family: 'Montserrat', 'sans';
			}

			body {
				line-height: 1;
				background: #181e23;
				font-style: normal;
				transition: font-size 0.3s ease-out;
				font-weight: 700;
				color: #ffffff;
				-webkit-font-smoothing: antialiased;
				font-size: 18px;
			}

			a {
				text-decoration: none;
				color: currentColor;
			}

			img {
				max-width: 100%;
				height: auto;
				border: 0;
			}
			h1 {
				font-size: 1.67rem;
				scroll-margin: 5rem;
				line-height: 2.5rem;
				font-weight: 900;
				letter-spacing: -0.025em;
				overflow-wrap: break-word;
				text-align: center;
			}

			h2 {
				font-size: 1.39rem;
				scroll-margin: 5rem;
				line-height: 2.25rem;
				font-weight: 700;
				letter-spacing: -0.025em;
				margin-top: 0px;
			}

			h3 {
				font-size: 1.25rem;
				scroll-margin: 5rem;
				line-height: 2rem;
				font-weight: 500;
				letter-spacing: -0.025em;
			}

			h4 {
				font-size: 1.11rem;
				scroll-margin: 5rem;
				line-height: 1.75rem;
				font-weight: 500;
			}

			p {
				font-weight: 500;
				line-height: 1.75rem;
				max-width: 65ch;
			}

			q {
				font-size: 1.11rem;
				scroll-margin: 5rem;
				line-height: 1.75rem;
				font-weight: 400;
				max-width: 65ch;
				text-align: center;
				font-style: italic;
				color: #ffda00;
				font-family: 'Delicious Handrawn';
				transition: font-size 0.3s ease-out;
				font-weight: 700;
				-webkit-font-smoothing: antialiased;
				font-size: 18px;
			}

			/* Tablet screen sizes */
			@media (min-width: 768px) {
				h1 {
					font-size: 2.22rem; /* Scaled up for tablet */
				}

				h2 {
					font-size: 1.94rem; /* Scaled up for tablet */
				}

				h3 {
					font-size: 1.67rem; /* Scaled up for tablet */
				}

				h4 {
					font-size: 1.39rem; /* Scaled up for tablet */
				}
			}

			/* Desktop screen sizes */
			@media (min-width: 1024px) {
				h1 {
					font-size: 2.78rem; /* Scaled up for desktop */
					line-height: 1;
				}

				h2 {
					font-size: 2.22rem; /* Scaled up for desktop */
				}

				h3 {
					font-size: 1.94rem; /* Scaled up for desktop */
				}

				h4 {
					font-size: 1.67rem; /* Scaled up for desktop */
				}
			}

			::selection {
				background-color: #ffda00;
				color: #181e23;
			}
		</style>
	</body>
</html>
