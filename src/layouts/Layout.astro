---
// * src/layouts/Layout.astro
export const prerender = true

import Header from '~/features/header_section/HeaderSection.astro'
interface Props {
	title: string
	description: string
}

const { title, description } = Astro.props
---

<!doctype html>
<html lang="en-US">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={Astro.url} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#181e23" />
		<meta name="msapplication-TileColor" content="#181e23" />
		<meta name="theme-color" content="#181e23" />
		{/* SEO Meta Tags */}
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="Ryan P Trainor Newsletter, Web Performance Tips, App Optimization Strategies, Sales Funnel Best Practices, Landing Page Design Insights, Tech Innovations by Ryan P Trainor, Software Development Techniques, Business Growth Hacks, Digital Marketing Trends, High-Performance Computing, Entrepreneurial Insights, User Experience Best Practices, Technology Leadership, Efficient Coding Practices, Ryan P Trainor Tech Insights"
		/>

		<link rel="manifest" href="/site.webmanifest" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		{/* Open Graph Meta Tags */}
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/og_image.png" />
		{/* Theme Color for Mobile Browsers */}
		<meta name="theme-color" content="#181E23" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="mx-auto max-w-7xl bg-brand_black p-4">
		<Header />
		<slot />
	</body>
</html>
<style is:global>
	@font-face {
		font-family: 'Montserrat';
		src:
			url('/fonts/montserrat-variablefont_wght-webfont.woff2') format('woff2'),
			url('/fonts/montserrat-variablefont_wght-webfont.woff') format('woff');
		font-weight: bold;
		font-style: normal;
		font-display: swap;
	}

	html {
		font-family: 'Montserrat', sans-serif;
		font-weight: bold;
	}
</style>
