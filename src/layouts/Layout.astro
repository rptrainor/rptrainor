---
import "@fontsource-variable/montserrat";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content='Astro description' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class='p-4 sm:px-12 max-w-prose flex flex-col gap-4 items-start mx-auto'>
    <header class='flex gap-4'>
      <img
        src='https://imagedelivery.net/xHZxKHrwCcaO8iTco-Njhg/b9e35925-14a2-4eab-3732-750c68910c00/logo'
        alt='RPTRAINOR'
        width='32'
        height='32'
        class='rounded-full'
      />
      <p>RPTRAINOR</p>
    </header>
    <slot />
  </body>
</html>
<style is:global>
  html {
    font-family: "Montserrat Variable", sans-serif;
    background: #13151a;
    color: #fff;
  }
  *,
  *:before,
  *:after {
    box-sizing: border-box;
    min-width: 0;
  }
  body {
    line-height: 1;
    font-style: normal;
    transition: font-size 0.3s ease-out;
    font-weight: 700;
    color: #ffffff;
    -webkit-font-smoothing: antialiased;
    font-size: 18px;
  }

  p {
    line-height: 1.75rem;
    max-width: 65ch;
  }
</style>
