---
import Layout from '~/layouts/Layout.astro'
import Hero from '~/features/hero_section/Hero.astro'
import TestimonialSingle from '~/features/testimonials_section/TestimonialSingle.astro'
import WhySection from '~/features/why_section/WhySection.astro'
import DifferentiationSection from '~/features/differentiation_section/DifferentiationSection.astro'
import FooterSection from '~/features/footer_section/FooterSection.astro'
import CalSection from '~/features/cal_section/CalSection.astro'
import FloatingSection from '~/features/floating_section/FloatingSection.astro'
---

<Layout
	title="Boost Conversions with Straight 100 Scores on Google Lighthouse: Expert Web Solutions & Insightful Analytics"
	description="Elevate your online business with RPTrainor's custom-engineered web solutions. Transition from 'no code' limitations to high-performance landing pages designed to maximize conversions and sales with top Google Lighthouse scores. Experience the difference that expertly optimized web pages can make in achieving your business goals."
>
	<main class="">
		<Hero />
		<div
			class="flex flex-col items-center justify-center gap-4 sm:mt-8 sm:gap-8 md:mt-12 md:gap-12"
		>
			<FloatingSection />
			<TestimonialSingle />
			<WhySection />
			<DifferentiationSection />
			<CalSection />
			<FooterSection />
		</div>
	</main>
</Layout>
